{
  "name": "@vorionsys/cognigate-sdk",
  "version": "1.0.5",
  "description": "Real-time AI governance decision engine — TypeScript SDK for the Cognigate API",
  "keywords": [
    "ai",
    "governance",
    "trust",
    "agents",
    "cognigate",
    "vorion"
  ],
  "license": "Apache-2.0",
  "author": "Vorion LLC",
  "homepage": "https://cognigate.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vorionsys/cognigate-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/vorionsys/cognigate-sdk/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./proof-bridge": {
      "types": "./dist/proof-bridge.d.ts",
      "import": "./dist/proof-bridge.js",
      "require": "./dist/proof-bridge.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@vorionsys/basis-spec": "^1.2.0",
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "@vorionsys/shared-constants": "^2.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup src/index.ts src/proof-bridge.ts --format esm,cjs --dts --clean",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "pack:check": "npm pack --dry-run",
    "changeset:version": "changeset version && npm install --package-lock-only",
    "changeset:release": "changeset publish"
  }
}
